<Window x:Class="Bookstore3.WPF.AppWindows.OptionsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:syncfusion="http://schemas.syncfusion.com/wpf"
        mc:Ignorable="d"
        Title="Options"
        Width="560"
        Height="360"
        WindowStyle="ToolWindow"
        ShowInTaskbar="False"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterOwner"
        MinWidth="480"
        MinHeight="300"
        Loaded="OptionsWindow_LoadedHandler"
        Closing="OptionsWindow_ClosingHandler">
    <Window.Resources>
        <Style x:Key="OptionLabelStyle" TargetType="TextBlock">
            <Setter Property="TextAlignment" Value="Right" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style x:Key="OptionTextBoxStyle" TargetType="syncfusion:SfTextBoxExt">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,4" />
            <Setter Property="Padding" Value="4,2" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
        </Style>
        <Style x:Key="DialogButtonStyle" TargetType="Button">
            <Setter Property="MinWidth" Value="80" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Margin" Value="6,0,0,0" />
            <Setter Property="Padding" Value="12,4" />
        </Style>
    </Window.Resources>

    <DockPanel LastChildFill="True">
        <Border DockPanel.Dock="Bottom"
                Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}"
                BorderBrush="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}"
                BorderThickness="0,1,0,0"
                Padding="8,8,8,8"
                Margin="0,8,0,0">
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button x:Name="OkButton"
                        Content="OK"
                        Style="{StaticResource DialogButtonStyle}"
                        IsDefault="True"
                        Click="OkButton_ClickHandler" />
                <Button x:Name="CancelButton"
                        Content="Cancel"
                        Style="{StaticResource DialogButtonStyle}"
                        IsCancel="True"
                        Click="CancelButton_ClickHandler" />
            </StackPanel>
        </Border>

        <TabControl x:Name="OptionsTabControl"
                    Margin="12,12,12,0">
            <TabItem Header="Open AI">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0"
                               Grid.Column="0"
                               Text="Open AI API Key"
                               Style="{StaticResource OptionLabelStyle}" />
                    <syncfusion:SfTextBoxExt x:Name="OpenAiApiKeyTextBox"
                                             Grid.Row="0"
                                             Grid.Column="1"
                                             Style="{StaticResource OptionTextBoxStyle}" />

                    <TextBlock Grid.Row="1"
                               Grid.Column="0"
                               Text="Open AI Model"
                               Style="{StaticResource OptionLabelStyle}" />
                    <syncfusion:SfTextBoxExt x:Name="OpenAiModelTextBox"
                                             Grid.Row="1"
                                             Grid.Column="1"
                                             Style="{StaticResource OptionTextBoxStyle}" />

                    <TextBlock Grid.Row="2"
                               Grid.Column="0"
                               Text="Open AI Endpoint"
                               Style="{StaticResource OptionLabelStyle}" />
                    <syncfusion:SfTextBoxExt x:Name="OpenAiEndpointTextBox"
                                             Grid.Row="2"
                                             Grid.Column="1"
                                             Style="{StaticResource OptionTextBoxStyle}" />
                </Grid>
            </TabItem>
            <TabItem Header="Google AI">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0"
                               Grid.Column="0"
                               Text="Google AI API Key"
                               Style="{StaticResource OptionLabelStyle}" />
                    <syncfusion:SfTextBoxExt x:Name="GoogleApiKeyTextBox"
                                             Grid.Row="0"
                                             Grid.Column="1"
                                             Style="{StaticResource OptionTextBoxStyle}" />

                    <TextBlock Grid.Row="1"
                               Grid.Column="0"
                               Text="Google AI Model"
                               Style="{StaticResource OptionLabelStyle}" />
                    <syncfusion:SfTextBoxExt x:Name="GoogleModelTextBox"
                                             Grid.Row="1"
                                             Grid.Column="1"
                                             Style="{StaticResource OptionTextBoxStyle}" />
                </Grid>
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>

