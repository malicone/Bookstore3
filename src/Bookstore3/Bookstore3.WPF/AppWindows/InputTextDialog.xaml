<Window x:Class="Bookstore3.WPF.AppWindows.InputTextDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Bookstore3.WPF"
        mc:Ignorable="d"
        Title="Input Required" Height="160" Width="350" 
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize" ShowInTaskbar="False"
        ContentRendered="Window_ContentRendered">
    
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- The Prompt Question -->
        <TextBlock Name="lblPrompt" Grid.Row="0" Margin="0,0,0,10" TextWrapping="Wrap">Please enter text:</TextBlock>

        <!-- The Input Box -->
        <TextBox Name="txtInput" Grid.Row="1" Height="25" VerticalAlignment="Top" />

        <!-- Action Buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Name="btnOk" Width="75" Margin="0,0,10,0" IsDefault="True" Click="BtnOk_Click">OK</Button>
            <Button Name="btnCancel" Width="75" IsCancel="True">Cancel</Button>
        </StackPanel>
    </Grid>
</Window>
