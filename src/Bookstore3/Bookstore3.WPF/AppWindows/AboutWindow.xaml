<Window x:Class="Bookstore3.WPF.AppWindows.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="About Bookstore"
        Width="460"
        Height="480"
        WindowStyle="ToolWindow"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">
    <Window.Resources>
        <Style x:Key="AboutTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="20" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#1A1A1A" />
            <Setter Property="HorizontalAlignment" Value="Center" />
        </Style>
        <Style x:Key="AboutBodyStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="#333333" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="TextAlignment" Value="Center" />
            <Setter Property="LineHeight" Value="20" />
        </Style>
        <Style x:Key="AboutHyperlinkStyle" TargetType="Hyperlink">
            <Setter Property="Foreground" Value="#0563C1" />
            <Setter Property="TextDecorations" Value="Underline" />
        </Style>
        <Style x:Key="AboutCloseButtonStyle" TargetType="Button">
            <Setter Property="MinWidth" Value="90" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Padding" Value="16,4" />
            <Setter Property="HorizontalAlignment" Value="Center" />
        </Style>
    </Window.Resources>

    <Border Margin="10"
            Padding="1"
            Background="#D0D0D0"
            CornerRadius="6">
        <Border Background="#FAFAFA"
                CornerRadius="5"
                Padding="18,16">
            <DockPanel LastChildFill="True">
                <Button DockPanel.Dock="Bottom"
                        Content="Close"
                        Margin="0,14,0,0"
                        Style="{StaticResource AboutCloseButtonStyle}"
                        IsDefault="True"
                        IsCancel="True"
                        Click="CloseButton_ClickHandler" />

                <Border DockPanel.Dock="Bottom"
                        Margin="0,12,0,0"
                        Padding="12,14"
                        Background="#F3F6FA"
                        BorderBrush="#D6E2F0"
                        BorderThickness="1"
                        CornerRadius="4">
                    <StackPanel>
                        <TextBlock HorizontalAlignment="Center"
                                   FontSize="12"
                                   Foreground="#444444"
                                   TextAlignment="Center"
                                   Text="Built with using KpzRepository.Sqlite package -" />
                        <TextBlock Margin="0,6,0,0"
                                   HorizontalAlignment="Center"
                                   FontSize="12">
                            <Hyperlink NavigateUri="https://www.nuget.org/packages/KpzRepository.Sqlite/1.0.0"
                                       Style="{StaticResource AboutHyperlinkStyle}"
                                       RequestNavigate="PackageLink_RequestNavigateHandler">
                                https://www.nuget.org/packages/KpzRepository.Sqlite/1.0.0
                            </Hyperlink>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <StackPanel Margin="0,4,0,4">
                        <Border HorizontalAlignment="Center"
                                Padding="12"
                                Margin="0,0,0,14"
                                Background="White"
                                BorderBrush="#D8D8D8"
                                BorderThickness="1"
                                CornerRadius="8"
                                SnapsToDevicePixels="True">
                            <Image x:Name="AppIconImage"
                                   Stretch="Uniform"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   RenderOptions.BitmapScalingMode="HighQuality"
                                   SnapsToDevicePixels="True"
                                   UseLayoutRounding="True" />
                        </Border>

                        <TextBlock x:Name="VersionTextBlock"
                                   Text="Bookstore version 3.0"
                                   Margin="0,0,0,14"
                                   Style="{StaticResource AboutTitleStyle}" />

                        <Border Margin="0,0,0,12"
                                Padding="14,12"
                                Background="White"
                                BorderBrush="#E4E4E4"
                                BorderThickness="1"
                                CornerRadius="4">
                            <StackPanel>
                                <TextBlock x:Name="CopyrightTextBlock"
                                           Style="{StaticResource AboutBodyStyle}" />
                                <TextBlock Margin="0,10,0,0"
                                           HorizontalAlignment="Center"
                                           FontSize="13">
                                    <Hyperlink x:Name="EmailHyperlink"
                                               Style="{StaticResource AboutHyperlinkStyle}"
                                               RequestNavigate="EmailHyperlink_RequestNavigateHandler">
                                        admin@kpzrepository.com
                                    </Hyperlink>
                                </TextBlock>
                                <TextBlock Margin="0,8,0,0"
                                           HorizontalAlignment="Center"
                                           FontSize="13">
                                    <Hyperlink x:Name="WebsiteHyperlink"
                                               Style="{StaticResource AboutHyperlinkStyle}"
                                               RequestNavigate="WebsiteHyperlink_RequestNavigateHandler">
                                        bookstore3.kpzrepository.com
                                    </Hyperlink>
                                </TextBlock>
                            </StackPanel>
                        </Border>
                    </StackPanel>
            </DockPanel>
        </Border>
    </Border>
</Window>
