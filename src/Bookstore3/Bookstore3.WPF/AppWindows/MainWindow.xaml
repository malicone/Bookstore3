<Window x:Class="Bookstore3.WPF.AppWindows.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
        xmlns:local="clr-namespace:Bookstore3.WPF"
        xmlns:utils="clr-namespace:Bookstore3.WPF.Utils"
        xmlns:syncfusion="http://schemas.syncfusion.com/wpf"
        mc:Ignorable="d"
        Title="Bookstore 3.0"
        Height="720"
        Width="1280"
        MinHeight="500"
        MinWidth="960"
        WindowStartupLocation="CenterScreen"
        Loaded="MainWindow_LoadedHandler"
        Closing="MainWindow_ClosingHandler"
        PreviewTextInput="MainWindow_PreviewTextInputHandler"
        PreviewKeyDown="MainWindow_PreviewKeyDownHandler">
    
    <Window.Resources>
        <Style x:Key="ToolbarButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="36" />
            <Setter Property="MinWidth" Value="110" />
            <Setter Property="Margin" Value="2,0" />
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
        </Style>
        <Style x:Key="ToolbarIconStyle" TargetType="iconPacks:PackIconMaterial">
            <Setter Property="Width" Value="18" />
            <Setter Property="Height" Value="18" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,0,8,0" />
        </Style>
        <Style x:Key="DetailNavButtonStyle" TargetType="Button" BasedOn="{StaticResource ToolbarButtonStyle}">
            <Setter Property="MinWidth" Value="90" />
        </Style>
        <Style x:Key="DetailLabelStyle" TargetType="TextBlock">
            <Setter Property="TextAlignment" Value="Right" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style x:Key="DetailValueStyle" TargetType="TextBox">
            <Setter Property="IsReadOnly" Value="True" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,2" />
            <Setter Property="Padding" Value="4,2" />
        </Style>
        <Style x:Key="DetailCopyButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="28" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Margin" Value="4,2,0,2" />
            <Setter Property="Padding" Value="4" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="BooksDataGridHeaderStyle" TargetType="syncfusion:GridHeaderCellControl">
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="Black" />
        </Style>
        <Style TargetType="syncfusion:GridCell">
            <Setter Property="BorderBrush" Value="{x:Static utils:AppConstants.GridCellBorderBrush}" />
        </Style>
        <Style TargetType="syncfusion:GridTableSummaryCell">
            <Setter Property="HorizontalContentAlignment" Value="Right" />
            <Setter Property="BorderBrush" Value="{x:Static utils:AppConstants.GridCellBorderBrush}" />
        </Style>
    </Window.Resources>

    <DockPanel LastChildFill="True">
        <!-- Toolbar -->
        <Border DockPanel.Dock="Top"
                Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}"
                BorderBrush="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}"
                BorderThickness="0,0,0,1"
                Padding="4,6">
            <DockPanel LastChildFill="False">
                <ToolBar Background="Transparent"
                         DockPanel.Dock="Left">
                    <Button x:Name="NewRecordButton"
                            Style="{StaticResource ToolbarButtonStyle}"
                            ToolTip="New record (Ctrl+N)"
                            Click="NewRecordButton_ClickHandler">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="Plus" Style="{StaticResource ToolbarIconStyle}" />
                            <TextBlock Text="New Record" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="RecordEditButton"
                            Style="{StaticResource ToolbarButtonStyle}"
                            ToolTip="Edit record (Ctrl+E)"
                            Click="RecordEditButton_ClickHandler">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="Pencil" Style="{StaticResource ToolbarIconStyle}" />
                            <TextBlock Text="Edit Record" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="DeleteRecordButton"
                            Style="{StaticResource ToolbarButtonStyle}"
                            ToolTip="Delete record (Ctrl+D)"
                            Click="DeleteRecordButton_ClickHandler">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="Delete" Style="{StaticResource ToolbarIconStyle}" />
                            <TextBlock Text="Delete Record" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <Separator />

                    <Button x:Name="RefreshDataButton"
                            Style="{StaticResource ToolbarButtonStyle}"
                            ToolTip="Refresh data (Ctrl+R)"
                            Click="RefreshDataButton_ClickHandler">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="Refresh" Style="{StaticResource ToolbarIconStyle}" />
                            <TextBlock Text="Refresh Data" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <Button x:Name="SearchButton"
                            Style="{StaticResource ToolbarButtonStyle}"
                            ToolTip="Search (Ctrl+S)"
                            Click="SearchButton_ClickHandler">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="Magnify" Style="{StaticResource ToolbarIconStyle}" />
                            <TextBlock Text="Search" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <Separator />

                    <Button x:Name="OptionsButton"
                            Style="{StaticResource ToolbarButtonStyle}"
                            ToolTip="Options"
                            Click="OptionsButton_ClickHandler">
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="Cog" Style="{StaticResource ToolbarIconStyle}" />
                            <TextBlock Text="Options" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <Separator />

                    <Menu VerticalAlignment="Center" Background="Transparent">
                        <MenuItem x:Name="GroupsToolbarMenuItem"
                                  Padding="12,6"
                                  Height="36"
                                  ToolTip="Groups (Ctrl+G)"
                                  InputGestureText="Ctrl+G">
                            <MenuItem.Header>
                                <StackPanel Orientation="Horizontal">
                                    <iconPacks:PackIconMaterial Kind="FormatListBulleted"
                                                                  Style="{StaticResource ToolbarIconStyle}" />
                                    <TextBlock Text="Groups" VerticalAlignment="Center" />
                                    <iconPacks:PackIconMaterial Kind="ChevronDown"
                                                                Width="14"
                                                                Height="14"
                                                                Margin="6,0,0,0"
                                                                VerticalAlignment="Center" />
                                </StackPanel>
                            </MenuItem.Header>
                            <MenuItem x:Name="GroupsMenuItem" Header="Groups" Click="GroupsMenuItem_ClickHandler" />
                            <MenuItem x:Name="PublishersMenuItem" Header="Publishers" Click="PublishersMenuItem_ClickHandler" />
                            <MenuItem x:Name="ShopsMenuItem" Header="Shops" Click="ShopsMenuItem_ClickHandler" />
                            <MenuItem x:Name="LanguagesMenuItem" Header="Languages" Click="LanguagesMenuItem_ClickHandler" />
                            <MenuItem x:Name="CitiesMenuItem" Header="Cities" Click="CitiesMenuItem_ClickHandler" />
                        </MenuItem>
                    </Menu>
                </ToolBar>
            </DockPanel>
        </Border>

        <!-- Status bar -->
        <StatusBar DockPanel.Dock="Bottom"
                   Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}">
            <StatusBarItem>
                <TextBlock x:Name="TotalBookCountText"
                           Text="Total Book Count 0"
                           VerticalAlignment="Center" />
            </StatusBarItem>
            <Separator />
            <StatusBarItem>
                <TextBlock x:Name="TotalGroupCountText"
                           Text="Total Group Count 0"
                           VerticalAlignment="Center" />
            </StatusBarItem>
            <Separator />
            <StatusBarItem>
                <TextBlock x:Name="TotalShopCountText"
                           Text="Total Shop Count 0"
                           VerticalAlignment="Center" />
            </StatusBarItem>
            <Separator />
            <StatusBarItem>
                <TextBlock x:Name="TotalPublisherCountText"
                           Text="Total Publisher Count 0"
                           VerticalAlignment="Center" />
            </StatusBarItem>
            <Separator />
            <StatusBarItem>
                <TextBlock x:Name="TotalLanguageCountText"
                           Text="Total Language Count 0"
                           VerticalAlignment="Center" />
            </StatusBarItem>
            <Separator />
            <StatusBarItem>
                <TextBlock x:Name="TotalCityCountText"
                           Text="Total City Count 0"
                           VerticalAlignment="Center" />
            </StatusBarItem>
        </StatusBar>

        <!-- Search bar (above status bar) -->
        <Border x:Name="SearchBarBorder"
                DockPanel.Dock="Bottom"
                Visibility="Collapsed"
                Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}"
                BorderBrush="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}"
                BorderThickness="0,1,0,0"
                Padding="4,4">
            <DockPanel LastChildFill="True">
                <Button DockPanel.Dock="Right"
                        Width="28"
                        Height="28"
                        Margin="4,0,0,0"
                        Padding="0"
                        VerticalAlignment="Center"
                        ToolTip="Close search"
                        Click="SearchBarCloseButton_ClickHandler">
                    <iconPacks:PackIconMaterial Kind="Close"
                                                Width="16"
                                                Height="16"
                                                VerticalAlignment="Center"
                                                HorizontalAlignment="Center" />
                </Button>
                <Button x:Name="RunTheSearchButton"
                        DockPanel.Dock="Right"
                        Height="28"
                        MinWidth="28"
                        Margin="4,0,0,0"
                        Padding="8,2"
                        VerticalAlignment="Center"
                        ToolTip="Run the search (hit Enter)"
                        Click="RunTheSearchButton_ClickHandler">
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconMaterial Kind="PlayCircleOutline"
                                                    Width="16"
                                                    Height="16"
                                                    VerticalAlignment="Center"
                                                    Margin="0,0,6,0" />
                        <TextBlock Text="Run The Search (Hit Enter)"
                                   FontSize="12"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
                <TextBlock DockPanel.Dock="Left"
                           Text="Search by Title or Author:"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0" />
                <TextBox x:Name="SearchTextBox"
                         VerticalAlignment="Center"
                         Padding="6,4"
                         KeyDown="SearchTextBox_KeyDownHandler" />
            </DockPanel>
        </Border>

        <!-- Tabs -->
        <TabControl x:Name="MainTabControl" Margin="8">
            <TabItem Header="List of All Books">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}"
                            BorderBrush="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}"
                            BorderThickness="0,0,0,1"
                            Padding="4,6"
                            Margin="0,0,0,8">
                        <StackPanel Orientation="Horizontal">
                            <Button x:Name="ColumnChooserButton"
                                    Style="{StaticResource ToolbarButtonStyle}"
                                    Click="ColumnChooserButton_ClickHandler"
                                    ToolTip="Show or hide columns for the book list (Ctrl+M)">
                                <StackPanel Orientation="Horizontal">
                                    <iconPacks:PackIconMaterial Kind="ViewColumn" Style="{StaticResource ToolbarIconStyle}" />
                                    <TextBlock Text="Columns" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                            <Button x:Name="ExportButton"
                                    Style="{StaticResource ToolbarButtonStyle}"
                                    Click="ExportButton_ClickHandler"
                                    ToolTip="Export selected rows (Ctrl+O)">
                                <Button.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem x:Name="ExportToExcelMenuItem"
                                                  Click="ExportToExcelMenuItem_ClickHandler">
                                            <MenuItem.Icon>
                                                <iconPacks:PackIconMaterial Kind="MicrosoftExcel"
                                                                            Width="16"
                                                                            Height="16"
                                                                            VerticalAlignment="Center" />
                                            </MenuItem.Icon>
                                            <MenuItem.Header>
                                                <TextBlock Text="Export To Excel" />
                                            </MenuItem.Header>
                                        </MenuItem>
                                        <MenuItem x:Name="ExportToCsvMenuItem"
                                                  Click="ExportToCsvMenuItem_ClickHandler">
                                            <MenuItem.Icon>
                                                <iconPacks:PackIconMaterial Kind="FileDelimitedOutline"
                                                                            Width="16"
                                                                            Height="16"
                                                                            VerticalAlignment="Center" />
                                            </MenuItem.Icon>
                                            <MenuItem.Header>
                                                <TextBlock Text="Export To CSV" />
                                            </MenuItem.Header>
                                        </MenuItem>
                                        <MenuItem x:Name="ExportToPdfMenuItem"
                                                  Click="ExportToPdfMenuItem_ClickHandler">
                                            <MenuItem.Icon>
                                                <iconPacks:PackIconMaterial Kind="FilePdfBox"
                                                                            Width="16"
                                                                            Height="16"
                                                                            VerticalAlignment="Center" />
                                            </MenuItem.Icon>
                                            <MenuItem.Header>
                                                <TextBlock Text="Export To PDF" />
                                            </MenuItem.Header>
                                        </MenuItem>
                                    </ContextMenu>
                                </Button.ContextMenu>
                                <StackPanel Orientation="Horizontal">
                                    <iconPacks:PackIconMaterial Kind="FileExportOutline" Style="{StaticResource ToolbarIconStyle}" />
                                    <TextBlock Text="Export" VerticalAlignment="Center" />
                                    <iconPacks:PackIconMaterial Kind="ChevronDown"
                                                                Width="14"
                                                                Height="14"
                                                                Margin="6,0,0,0"
                                                                VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Border>

                    <syncfusion:SfDataGrid x:Name="BooksDataGrid"
                                           Grid.Row="1"
                                           AutoGenerateColumns="False"
                                           HeaderStyle="{StaticResource BooksDataGridHeaderStyle}"
                                           AllowSorting="True"
                                           AllowTriStateSorting="True"
                                           ShowSortNumbers="True"
                                           AllowGrouping="True"
                                           ShowGroupDropArea="True"
                                           IsGroupDropAreaExpanded="True"
                                           GroupDropAreaText="Drag a column header here to group by that column."
                                           AllowFiltering="True"
                                           LiveDataUpdateMode="AllowDataShaping"
                                           AllowDraggingColumns="True"
                                           AllowResizingColumns="True"
                                           AllowResizingHiddenColumns="True"
                                           ColumnSizer="Star"
                                           GridLinesVisibility="Both"
                                           HeaderLinesVisibility="Both"
                                           HeaderRowHeight="26"
                                           RowHeight="24"
                                           SelectionMode="Extended"
                                           SelectionUnit="Row">
                        <syncfusion:SfDataGrid.Columns>
                            <syncfusion:GridTextColumn MappingName="id"
                                                       HeaderText="Id"
                                                       TextAlignment="Right"
                                                       Width="100" />
                            <syncfusion:GridDateTimeColumn MappingName="crt_date_time"
                                                         HeaderText="Created At"
                                                         Width="160"
                                                         Pattern="CustomPattern"
                                                         CustomPattern="{x:Static utils:AppConstants.DefaultDateTimeFormat}" />
                            <syncfusion:GridTextColumn MappingName="author"
                                                       HeaderText="Author"
                                                       Width="160" />
                            <syncfusion:GridTextColumn MappingName="title"
                                                       HeaderText="Title"
                                                       Width="220" />
                            <syncfusion:GridTextColumn MappingName="group_name"
                                                       HeaderText="Group"
                                                       Width="160" />
                            <syncfusion:GridTextColumn MappingName="publisher_name"
                                                       HeaderText="Publisher"
                                                       Width="140" />
                            <syncfusion:GridNumericColumn MappingName="page_count"
                                                          HeaderText="Page Count"
                                                          NumberDecimalDigits="0"
                                                          Width="90" />
                            <syncfusion:GridNumericColumn MappingName="publish_year"
                                                          HeaderText="Publish Year"
                                                          NumberDecimalDigits="0"
                                                          Width="100" />
                            <syncfusion:GridNumericColumn MappingName="edition"
                                                          HeaderText="Edition"
                                                          NumberDecimalDigits="0"
                                                          Width="70" />
                            <syncfusion:GridTextColumn MappingName="format"
                                                       HeaderText="Format"
                                                       Width="100" />
                            <syncfusion:GridTextColumn MappingName="isbn"
                                                       HeaderText="ISBN"
                                                       Width="140" />
                            <syncfusion:GridTextColumn MappingName="price"
                                                       HeaderText="Price"
                                                       Width="120"
                                                       TextAlignment="Right">
                                <syncfusion:GridTextColumn.DisplayBinding>
                                    <Binding Path="price"
                                             StringFormat="{x:Static utils:AppConstants.DefaultPriceDataFormatString}" />
                                </syncfusion:GridTextColumn.DisplayBinding>
                            </syncfusion:GridTextColumn>
                            <syncfusion:GridDateTimeColumn MappingName="date_when_get"
                                                         HeaderText="Received At"
                                                         Width="160"
                                                         Pattern="CustomPattern"
                                                         CustomPattern="{x:Static utils:AppConstants.DefaultDateTimeFormat}" />
                            <syncfusion:GridCheckBoxColumn MappingName="wrapper"
                                                         HeaderText="Hardcopy"
                                                         AllowEditing="False"
                                                         Width="80" />
                            <syncfusion:GridTextColumn MappingName="language_name"
                                                       HeaderText="Language"
                                                       Width="110" />
                            <syncfusion:GridTextColumn MappingName="city_name"
                                                       HeaderText="City"
                                                       Width="110" />
                            <syncfusion:GridTextColumn MappingName="shop_name"
                                                       HeaderText="Shop"
                                                       Width="130" />
                            <syncfusion:GridCheckBoxColumn MappingName="has_digit_copy"
                                                         HeaderText="Digit Copy"
                                                         AllowEditing="False"
                                                         Width="90" />
                        </syncfusion:SfDataGrid.Columns>
                        <syncfusion:SfDataGrid.TableSummaryRows>
                            <syncfusion:GridTableSummaryRow ShowSummaryInRow="False"
                                                            Position="Bottom">
                                <syncfusion:GridSummaryRow.SummaryColumns>
                                    <syncfusion:GridSummaryColumn MappingName="id"
                                                                  Name="IdCount"
                                                                  SummaryType="CountAggregate"
                                                                  Format="Count: {Count}" />
                                    <syncfusion:GridSummaryColumn MappingName="price"
                                                                  Name="PriceSum"
                                                                  SummaryType="DoubleAggregate"
                                                                  Format="Sum: {Sum:0.00}" />
                                </syncfusion:GridSummaryRow.SummaryColumns>
                            </syncfusion:GridTableSummaryRow>
                        </syncfusion:SfDataGrid.TableSummaryRows>
                    </syncfusion:SfDataGrid>
                </Grid>
            </TabItem>

            <TabItem Header="Details of Selected Book">
                <Grid Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="360" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- Row 1: navigation toolbar -->
                    <Border Grid.Row="0"
                            Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}"
                            BorderBrush="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}"
                            BorderThickness="0,0,0,1"
                            Padding="4,6"
                            Margin="0,0,0,8">
                        <StackPanel Orientation="Horizontal">
                            <Button x:Name="DetailFirstButton"
                                    Style="{StaticResource DetailNavButtonStyle}"
                                    ToolTip="Move to the first record in the list (F9)"
                                    Click="DetailFirstButton_ClickHandler">
                                <StackPanel Orientation="Horizontal">
                                    <iconPacks:PackIconMaterial Kind="SkipPrevious" Style="{StaticResource ToolbarIconStyle}" />
                                    <TextBlock Text="First (F9)" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                            <Button x:Name="DetailPreviousButton"
                                    Style="{StaticResource DetailNavButtonStyle}"
                                    ToolTip="Move to the previous record in the list (F10)"
                                    Click="DetailPreviousButton_ClickHandler">
                                <StackPanel Orientation="Horizontal">
                                    <iconPacks:PackIconMaterial Kind="ChevronLeft" Style="{StaticResource ToolbarIconStyle}" />
                                    <TextBlock Text="Previous (F10)" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                            <Button x:Name="DetailNextButton"
                                    Style="{StaticResource DetailNavButtonStyle}"
                                    ToolTip="Move to the next record in the list (F11)"
                                    Click="DetailNextButton_ClickHandler">
                                <StackPanel Orientation="Horizontal">
                                    <iconPacks:PackIconMaterial Kind="ChevronRight" Style="{StaticResource ToolbarIconStyle}" />
                                    <TextBlock Text="Next (F11)" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                            <Button x:Name="DetailLastButton"
                                    Style="{StaticResource DetailNavButtonStyle}"
                                    ToolTip="Move to the last record in the list (F12)"
                                    Click="DetailLastButton_ClickHandler">
                                <StackPanel Orientation="Horizontal">
                                    <iconPacks:PackIconMaterial Kind="SkipNext" Style="{StaticResource ToolbarIconStyle}" />
                                    <TextBlock Text="Last (F12)" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Border>

                    <!-- Row 2: cover image + book fields -->
                    <Grid Grid.Row="1" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" MinWidth="200" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                Width="200"
                                Height="300"
                                Margin="16,0,16,0"
                                Background="#F0F0F0"
                                BorderBrush="#D0D0D0"
                                BorderThickness="1">
                            <Grid>
                                <Image x:Name="CoverImage"                                       
                                       Stretch="Uniform"
                                       MaxWidth="198"
                                       MaxHeight="298"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Visibility="Collapsed" />
                                <StackPanel x:Name="NoImagePanel"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center">
                                    <iconPacks:PackIconMaterial Kind="ImageOff"
                                                                Width="48"
                                                                Height="48"
                                                                Foreground="#9E9E9E"
                                                                HorizontalAlignment="Center" />
                                    <TextBlock Text="No image"
                                               Margin="0,8,0,0"
                                               Foreground="#757575"
                                               FontSize="14"
                                               HorizontalAlignment="Center" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Grid Grid.Column="1"
                              Margin="0,0,8,0"
                              VerticalAlignment="Top">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="80" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <!-- Row 0: small | small -->
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Id" Style="{StaticResource DetailLabelStyle}" />
                            <TextBox Grid.Row="0" Grid.Column="1" x:Name="DetailIdText" Width="250" Style="{StaticResource DetailValueStyle}" />
                            <TextBlock Grid.Row="0" Grid.Column="2" Text="Created At" Style="{StaticResource DetailLabelStyle}" Margin="16,0,8,0" />
                            <TextBox Grid.Row="0" Grid.Column="3" x:Name="DetailCreatedAtText" Width="250" Style="{StaticResource DetailValueStyle}" />

                            <!-- Row 1: long -->
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Author" Style="{StaticResource DetailLabelStyle}" />
                            <Grid Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0"
                                         x:Name="DetailAuthorText"
                                         Style="{StaticResource DetailValueStyle}" />
                                <Button Grid.Column="1"
                                        x:Name="CopyAuthorButton"
                                        Style="{StaticResource DetailCopyButtonStyle}"
                                        Click="CopyAuthorButton_ClickHandler"
                                        ToolTip="Copy Author to clipboard">
                                    <iconPacks:PackIconMaterial Kind="ContentCopy"
                                                                Width="16"
                                                                Height="16" />
                                </Button>
                            </Grid>

                            <!-- Row 2: long -->
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Title" Style="{StaticResource DetailLabelStyle}" />
                            <Grid Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0"
                                         x:Name="DetailTitleText"
                                         Style="{StaticResource DetailValueStyle}" />
                                <Button Grid.Column="1"
                                        x:Name="CopyTitleButton"
                                        Style="{StaticResource DetailCopyButtonStyle}"
                                        Click="CopyTitleButton_ClickHandler"
                                        ToolTip="Copy Title to clipboard">
                                    <iconPacks:PackIconMaterial Kind="ContentCopy"
                                                                Width="16"
                                                                Height="16" />
                                </Button>
                            </Grid>

                            <!-- Row 3: long -->
                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Group" Style="{StaticResource DetailLabelStyle}" />
                            <TextBox Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="3" x:Name="DetailGroupText" Width="700" Style="{StaticResource DetailValueStyle}" />

                            <!-- Row 4: long -->
                            <TextBlock Grid.Row="4" Grid.Column="0" Text="ISBN" Style="{StaticResource DetailLabelStyle}" />
                            <Grid Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0"
                                         x:Name="DetailIsbnText"
                                         Style="{StaticResource DetailValueStyle}" />
                                <Button Grid.Column="1"
                                        x:Name="CopyIsbnButton"
                                        Style="{StaticResource DetailCopyButtonStyle}"
                                        Click="CopyIsbnButton_ClickHandler"
                                        ToolTip="Copy ISBN to clipboard">
                                    <iconPacks:PackIconMaterial Kind="ContentCopy"
                                                                Width="16"
                                                                Height="16" />
                                </Button>
                            </Grid>

                            <!-- Row 5: small | small -->
                            <TextBlock Grid.Row="5" Grid.Column="0" Text="Edition" Style="{StaticResource DetailLabelStyle}" />
                            <TextBox Grid.Row="5" Grid.Column="1" x:Name="DetailEditionText" Width="250" Style="{StaticResource DetailValueStyle}" />
                            <TextBlock Grid.Row="5" Grid.Column="2" Text="Page Count" Style="{StaticResource DetailLabelStyle}" Margin="16,0,8,0" />
                            <TextBox Grid.Row="5" Grid.Column="3" x:Name="DetailPageCountText" Width="250" Style="{StaticResource DetailValueStyle}" />

                            <!-- Row 6: small | small -->
                            <TextBlock Grid.Row="6" Grid.Column="0" Text="Publisher" Style="{StaticResource DetailLabelStyle}" />
                            <TextBox Grid.Row="6" Grid.Column="1" x:Name="DetailPublisherText" Width="250" Style="{StaticResource DetailValueStyle}" />
                            <TextBlock Grid.Row="6" Grid.Column="2" Text="Shop" Style="{StaticResource DetailLabelStyle}" Margin="16,0,8,0" />
                            <TextBox Grid.Row="6" Grid.Column="3" x:Name="DetailShopText" Width="250" Style="{StaticResource DetailValueStyle}" />

                            <!-- Row 7: small | small -->
                            <TextBlock Grid.Row="7" Grid.Column="0" Text="Format" Style="{StaticResource DetailLabelStyle}" />
                            <TextBox Grid.Row="7" Grid.Column="1" x:Name="DetailFormatText" Width="250" Style="{StaticResource DetailValueStyle}" />
                            <TextBlock Grid.Row="7" Grid.Column="2" Text="Publish Year" Style="{StaticResource DetailLabelStyle}" Margin="16,0,8,0" />
                            <TextBox Grid.Row="7" Grid.Column="3" x:Name="DetailPublishYearText" Width="250" Style="{StaticResource DetailValueStyle}" />

                            <!-- Row 8: small | small -->
                            <TextBlock Grid.Row="8" Grid.Column="0" Text="Price" Style="{StaticResource DetailLabelStyle}" />
                            <TextBox Grid.Row="8" Grid.Column="1" x:Name="DetailPriceText" Width="250" Style="{StaticResource DetailValueStyle}" />
                            <TextBlock Grid.Row="8" Grid.Column="2" Text="Received At" Style="{StaticResource DetailLabelStyle}" Margin="16,0,8,0" />
                            <TextBox Grid.Row="8" Grid.Column="3" x:Name="DetailGotAtText" Width="250" Style="{StaticResource DetailValueStyle}" />

                            <!-- Row 9: small | small -->
                            <TextBlock Grid.Row="9" Grid.Column="0" Text="Hardcover" Style="{StaticResource DetailLabelStyle}" />
                            <TextBox Grid.Row="9" Grid.Column="1" x:Name="DetailHardcoverText" Width="250" Style="{StaticResource DetailValueStyle}" />
                            <TextBlock Grid.Row="9" Grid.Column="2" Text="Language" Style="{StaticResource DetailLabelStyle}" Margin="16,0,8,0" />
                            <TextBox Grid.Row="9" Grid.Column="3" x:Name="DetailLanguageText" Width="250" Style="{StaticResource DetailValueStyle}" />

                            <!-- Row 10: small | small -->
                            <TextBlock Grid.Row="10" Grid.Column="0" Text="Digit Copy" Style="{StaticResource DetailLabelStyle}" />
                            <TextBox Grid.Row="10" Grid.Column="1" x:Name="DetailDigitCopyText" Width="250" Style="{StaticResource DetailValueStyle}" />
                            <TextBlock Grid.Row="10" Grid.Column="2" Text="City" Style="{StaticResource DetailLabelStyle}" Margin="16,0,8,0" />
                            <TextBox Grid.Row="10" Grid.Column="3" x:Name="DetailCityText" Width="250" Style="{StaticResource DetailValueStyle}" />

                            <!-- Row 11: long -->
                            <TextBlock Grid.Row="11" Grid.Column="0" Text="Book File" Style="{StaticResource DetailLabelStyle}" />
                            <Grid Grid.Row="11" Grid.Column="1" Grid.ColumnSpan="3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0"
                                         x:Name="DetailBookFileText"
                                         Style="{StaticResource DetailValueStyle}" />
                                <Button Grid.Column="1"
                                        x:Name="CopyBookFileButton"
                                        Style="{StaticResource DetailCopyButtonStyle}"
                                        Click="CopyBookFileButton_ClickHandler"
                                        ToolTip="Copy Book File to clipboard">
                                    <iconPacks:PackIconMaterial Kind="ContentCopy"
                                                                Width="16"
                                                                Height="16" />
                                </Button>
                                <Button Grid.Column="2"
                                        x:Name="OpenBookFileButton"
                                        Style="{StaticResource DetailCopyButtonStyle}"
                                        Click="OpenBookFileButton_ClickHandler"
                                        ToolTip="Open Book File">
                                    <iconPacks:PackIconMaterial Kind="Launch"
                                                                Width="16"
                                                                Height="16" />
                                </Button>
                            </Grid>
                        </Grid>
                    </Grid>

                    <!-- Row 3: annotation + details -->
                    <Grid Grid.Row="2" MinHeight="120">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <DockPanel Grid.Column="0" Margin="0,0,4,0">
                            <TextBlock DockPanel.Dock="Top"
                                       Text="Annotation"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,4" />
                            <TextBox x:Name="DetailAnnotationText"
                                     FontSize="14"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"
                                     IsReadOnly="True"
                                     IsReadOnlyCaretVisible="True"
                                     VerticalAlignment="Stretch" />
                        </DockPanel>

                        <DockPanel Grid.Column="1" Margin="4,0,0,0">
                            <TextBlock DockPanel.Dock="Top"
                                       Text="Details"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,4" />
                            <TextBox x:Name="DetailDetailsText"
                                     FontSize="14"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"
                                     IsReadOnly="True"
                                     IsReadOnlyCaretVisible="True"
                                     VerticalAlignment="Stretch" />
                        </DockPanel>
                    </Grid>
                </Grid>
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>
