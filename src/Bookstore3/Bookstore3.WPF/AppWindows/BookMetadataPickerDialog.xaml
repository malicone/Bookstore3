<Window x:Class="Bookstore3.WPF.AppWindows.BookMetadataPickerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Bookstore3.WPF.AppWindows"
        mc:Ignorable="d"
        Title="Select Book"
        Height="520"
        Width="820"
        MinHeight="360"
        MinWidth="560"
        WindowStyle="ToolWindow"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        ShowInTaskbar="False"
        Loaded="Window_LoadedHandler"
        Closing="Window_ClosingHandler">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

        <Style x:Key="DialogButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="90" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Margin" Value="8,0,0,0" />
            <Setter Property="Padding" Value="12,4" />
        </Style>

        <Style x:Key="ResultsListViewItemStyle" TargetType="ListViewItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Padding" Value="6" />
            <Setter Property="Margin" Value="0,0,0,4" />
        </Style>

        <Style x:Key="SourceHyperlinkStyle" TargetType="Hyperlink">
            <Setter Property="Foreground" Value="#0563C1" />
            <Setter Property="TextDecorations" Value="Underline" />
            <EventSetter Event="RequestNavigate" Handler="SourceUrl_RequestNavigateHandler" />
        </Style>

        <DataTemplate x:Key="BookMetadataPickerItemTemplate">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Width="{x:Static local:BookMetadataPickerItem.CoverWidth}"
                        Height="{x:Static local:BookMetadataPickerItem.CoverHeight}"
                        Margin="0,0,10,0"
                        Background="#F3F3F3"
                        BorderBrush="#D0D0D0"
                        BorderThickness="1">
                    <Grid>
                        <Image Source="{Binding CoverImage}"
                               Stretch="Uniform"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Visibility="{Binding HasCoverImage, Converter={StaticResource BooleanToVisibilityConverter}}" />
                        <TextBlock Text="No cover"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   TextAlignment="Center"
                                   FontSize="11"
                                   Foreground="#888888"
                                   TextWrapping="Wrap"
                                   Margin="4">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasCoverImage}" Value="False">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                </Border>

                <StackPanel Grid.Column="1"
                            VerticalAlignment="Center">
                    <TextBlock Text="{Binding DisplayText}"
                               FontWeight="SemiBold"
                               FontSize="14"
                               TextWrapping="Wrap" />
                    <TextBlock Text="{Binding ExtendedDescription}"
                               Margin="0,6,0,0"
                               FontSize="12"
                               Foreground="#444444"
                               TextWrapping="Wrap" />
                    <TextBlock Margin="0,6,0,0"
                               FontSize="11"
                               TextWrapping="Wrap">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasSourceUrl}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                        <Run Text="Source: "
                             Foreground="#666666" />
                        <Hyperlink NavigateUri="{Binding SourceUrl, Mode=OneWay}"
                                   Style="{StaticResource SourceHyperlinkStyle}">
                            <Run Text="{Binding SourceUrl, Mode=OneWay}" />
                        </Hyperlink>
                    </TextBlock>
                </StackPanel>
            </Grid>
        </DataTemplate>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Margin="0,0,0,10"
                   Text="Select the most relevant book from the search results:"
                   TextWrapping="Wrap" />

        <ListView x:Name="ResultsListView"
                  Grid.Row="1"
                  ItemTemplate="{StaticResource BookMetadataPickerItemTemplate}"
                  ItemContainerStyle="{StaticResource ResultsListViewItemStyle}"
                  HorizontalContentAlignment="Stretch"
                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                  MouseDoubleClick="ResultsListView_MouseDoubleClickHandler" />

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,12,0,0">
            <Button x:Name="OkButton"
                    Content="OK"
                    Style="{StaticResource DialogButtonStyle}"
                    IsDefault="True"
                    Click="OkButton_ClickHandler" />
            <Button Content="Cancel"
                    Style="{StaticResource DialogButtonStyle}"
                    IsCancel="True" />
        </StackPanel>
    </Grid>
</Window>
